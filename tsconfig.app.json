{
    "extends": "@tsconfig/svelte/tsconfig.json",
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
        "target": "ES2022",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "types": ["svelte", "vite/client"],
        "noEmit": true,
        "allowJs": true,
        "checkJs": false,
        "moduleDetection": "force",
        "baseUrl": ".",
        "paths": {
            "$lib/*": ["src/lib/*"],
            "$data/*": ["src/data/*"],
            "$styles/*": ["src/styles/*"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.js", "src/**/*.svelte"]
}
